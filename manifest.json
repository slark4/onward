{
  "manifest_version": 3,
  "name": "Onward",
  "version": "0.1.0",
  "description": "A reset, not a block. Guided grounding sessions instead of hard blocks.",

  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*",
    "*://*.reddit.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.instagram.com/*"
  ],

  "background": {
    "service_worker": "src/background/service_worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.tiktok.com/*",
        "*://*.reddit.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.instagram.com/*"
      ],
      "js": ["src/shared/messages.js", "src/content/panel.js", "src/content/content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icon-16.png",
    "48":  "icon-48.png",
    "128": "icon-128.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Onward",
    "default_icon": {
      "16":  "icon-16.png",
      "48":  "icon-48.png",
      "128": "icon-128.png"
    }
  },

  "options_page": "src/options/options.html",

  "web_accessible_resources": [
    {
      "resources": ["src/shared/content_pool.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
